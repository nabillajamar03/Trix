<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TalentTrixx | Job Applicants for Fresh Graduates</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(135deg,#6A0DAD,#A855F7,#FF69B4);
    min-height:100vh;
    color:white;
    overflow-x:hidden;
}

body::before{
    content:"";
    position:fixed;
    width:600px;
    height:600px;
    background:rgba(255,255,255,0.12);
    border-radius:50%;
    top:-200px;
    right:-150px;
    filter:blur(50px);
}

body::after{
    content:"";
    position:fixed;
    width:500px;
    height:500px;
    background:rgba(255,255,255,0.08);
    border-radius:50%;
    bottom:-180px;
    left:-100px;
    filter:blur(60px);
}

header{
    text-align:center;
    padding:80px 20px 50px;
}

.logo{
    font-size:4rem;
    font-weight:700;
    background:linear-gradient(90deg,#ffffff,#ffd6f5);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    text-shadow:0 0 20px rgba(255,255,255,0.3);
}

.subtitle{
    margin-top:12px;
    font-size:1.2rem;
    color:#ffe4f7;
}

.hero-title{
    margin-top:25px;
    font-size:2.8rem;
    font-weight:700;
}

.hero-text{
    max-width:700px;
    margin:20px auto;
    line-height:1.8;
    color:#fdf2f8;
}

.cta-btn{
    display:inline-block;
    margin-top:20px;
    padding:15px 35px;
    background:white;
    color:#9d4edd;
    text-decoration:none;
    border-radius:50px;
    font-weight:600;
    transition:0.3s;
    box-shadow:0 8px 30px rgba(255,255,255,0.25);
}

.cta-btn:hover{
    transform:translateY(-5px) scale(1.05);
}

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
}

.section-title{
    text-align:center;
    margin:60px 0 30px;
    font-size:2rem;
}

.jobs{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:rgba(255,255,255,0.12);
    backdrop-filter:blur(15px);
    border:1px solid rgba(255,255,255,0.2);
    padding:30px;
    border-radius:25px;
    transition:0.3s;
    box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 20px 40px rgba(255,105,180,0.3);
}

.card h3{
    margin-bottom:15px;
    color:#fff0fa;
}

.card p{
    line-height:1.7;
    color:#fce7f3;
}

.apply-btn{
    display:inline-block;
    margin-top:20px;
    padding:10px 25px;
    background:linear-gradient(90deg,#ff69b4,#c026d3);
    color:white;
    text-decoration:none;
    border-radius:30px;
    font-weight:600;
}

.form-section{
    margin:80px 0;
    background:rgba(255,255,255,0.12);
    backdrop-filter:blur(20px);
    padding:40px;
    border-radius:30px;
}

.form-section h2{
    text-align:center;
    margin-bottom:30px;
}

form{
    display:flex;
    flex-direction:column;
    gap:18px;
}

input, select, textarea{
    padding:16px;
    border:none;
    border-radius:15px;
    background:rgba(255,255,255,0.15);
    color:white;
    font-size:1rem;
}

input::placeholder,
textarea::placeholder{
    color:#fbcfe8;
}

option{
    color:black;
}

.submit-btn{
    background:linear-gradient(90deg,#ff69b4,#8b5cf6);
    border:none;
    color:white;
    padding:16px;
    border-radius:15px;
    font-size:1rem;
    font-weight:600;
    cursor:pointer;
    transition:0.3s;
}

.submit-btn:hover{
    transform:scale(1.02);
}

footer{
    text-align:center;
    padding:25px;
    background:rgba(0,0,0,0.15);
    color:#ffe4f7;
}
</style>
</head>

<body>

<header>
    <h1 class="logo">TalentTrixx</h1>
    <p class="subtitle">Where Fresh Graduates Build Their Future</p>

    <h2 class="hero-title">
        Job Applicants for Fresh Graduates
    </h2>

    <p class="hero-text">
        Discover exciting entry-level opportunities, connect with leading employers,
        and launch your professional journey through an innovative and modern
        recruitment experience.
    </p>

    <a href="#apply" class="cta-btn">Start Your Career ✨</a>
</header>

<div class="container">

    <h2 class="section-title">Featured Graduate Opportunities</h2>

    <section class="jobs">

        <div class="card">
            <h3>💼 Customer Service Executive</h3>
            <p>
                Build communication skills while supporting customers in a fast-paced environment.
            </p>
            <a href="#" class="apply-btn">Apply Now</a>
        </div>

        <div class="card">
            <h3>📱 Digital Marketing Associate</h3>
            <p>
                Learn social media management, branding, and digital campaign strategies.
            </p>
            <a href="#" class="apply-btn">Apply Now</a>
        </div>

        <div class="card">
            <h3>💻 Junior IT Support Analyst</h3>
            <p>
                Gain hands-on experience in troubleshooting systems and supporting business users.
            </p>
            <a href="#" class="apply-btn">Apply Now</a>
        </div>

    </section>

    <section class="form-section" id="apply">

        <h2>Apply via TalentTrixx</h2>

        <form>

            <input type="text" placeholder="Full Name" required>

            <input type="email" placeholder="Email Address" required>

            <input type="text" placeholder="University / College" required>

            <input type="text" placeholder="Field of Study" required>

            <select required>
                <option value="">Select Position</option>
                <option>Customer Service Executive</option>
                <option>Digital Marketing Associate</option>
                <option>Junior IT Support Analyst</option>
            </select>

            <textarea rows="5"
            placeholder="Tell us about yourself and your career goals..."></textarea>

            <button class="submit-btn">
                Submit Application 🚀
            </button>

        </form>

    </section>

</div>

<footer>
    © 2026 TalentTrixx Recruitment Platform • Empowering Fresh Graduate Careers
</footer>
<elevenlabs-convai agent-id="agent_0801kwb9artceawvyfahv5cgasvq"></elevenlabs-convai><script src="https://unpkg.com/@elevenlabs/convai-widget-embed" async type="text/javascript"></script>
</body>
</html>
